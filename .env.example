# Copy this file to ".env" and fill in your key. The app auto-loads ".env" at
# startup (it is git-ignored). Real environment variables override these.

# --- Report Assistant (MindRouter, U-Idaho LLM gateway) --------------------
# Service API key (looks like mr2_...). Required to enable the Report Assistant.
MINDROUTER_API_KEY=

# Model. "default-llm" is MindRouter's stable alias that always resolves to the
# best current general model (auto-assignment). Leave as-is unless you want a
# specific model id from /v1/models.
MINDROUTER_MODEL=default-llm

# Optional
MINDROUTER_BASE_URL=https://mindrouter.uidaho.edu/v1
MINDROUTER_FALLBACK_MODEL=default-llm
MINDROUTER_TEMPERATURE=0.3
MINDROUTER_MAX_TOKENS=1400
MINDROUTER_TIMEOUT=60

# --- Data ------------------------------------------------------------------
# RGT_DATA_FILE=data/rgt24_new.csv
